# Path to the embedded Kuzu database directory.
KUZU_DB_PATH=./data/kuzu-demo

# Keep true for first local run. Set false when connecting to your own Kuzu DB.
KUZU_AUTO_CREATE_SCHEMA=true
KUZU_AUTO_SEED=true

# MCP server metadata shown to MCP clients.
MCP_SERVER_NAME=kuzu-knowledge-graph
MCP_SERVER_VERSION=0.1.0

